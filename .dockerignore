# Excluir todo lo relacionado con Git
.git/
.github/
.gitignore

# Excluir los entornos virtuales
venv/
.venv/
env/

# Excluir la base de datos local (se manejará con un volumen)
*.db
*.sqlite
*.sqlite3
fichaje.db
instance/

# Excluir archivos de caché de Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Excluir archivos de configuración de Docker (no deben estar DENTRO de la imagen)
Dockerfile
docker-compose.yml
.dockerignore

# Excluir archivos de entorno
.env

# Excluir documentación
README.md

# Excluir archivos del sistema operativo
.DS_Store
Thumbs.db

# Excluir otros archivos de la app
logs/
logs/*

# NOTA: migrations/ debe ir DENTRO de la imagen. Contiene la baseline de Alembic
# (ae8bd2a26bb2) que la BD ya tiene sellada en alembic_version. Si se excluye,
# el entrypoint hace 'flask db init' sobre una carpeta vacía y 'flask db upgrade'
# falla con "Can't locate revision identified by ...".